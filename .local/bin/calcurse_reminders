#!/bin/bash

## Activate the notifications for calcurse activities
/usr/bin/nohup /usr/bin/python /home/mqx/.local/bin/ccursereminders.py 1  > /dev/null 2>&1 &
/usr/bin/nohup /usr/bin/python /home/mqx/.local/bin/ccursereminders.py 4 > /dev/null 2>&1 &
/usr/bin/nohup /usr/bin/python /home/mqx/.local/bin/ccursereminders.py 16 > /dev/null 2>&1 &
notify-send "📅 Calcurse" "Notifications activated"
